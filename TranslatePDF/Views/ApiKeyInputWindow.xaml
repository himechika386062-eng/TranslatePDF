<Window x:Class="TranslatePDF.Views.ApiKeyInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeepL APIキー設定"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <StackPanel Margin="20">
        <TextBlock
            Text="DeepL APIキーを入力してください"
            FontWeight="Bold"
            Margin="0,0,0,8"/>

        <TextBox
            x:Name="ApiKeyBox"
            Width="360"
            Height="26"
            Margin="0,0,0,12"/>

        <Button
            Content="保存"
            Width="90"
            HorizontalAlignment="Right"
            Click="Save_Click"/>
    </StackPanel>
</Window>